{
  "expo": {
    "name": "Birthday Buddy",
    "slug": "birthday-buddy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "birthdaybuddy",
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.birthdaybuddy.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Birthday Buddy uses your photos so you can add a picture to a friend's profile."
      }
    },
    "android": {
      "package": "com.birthdaybuddy.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#FF3B30"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Birthday Buddy uses your photos so you can add a picture to a friend's profile."
        }
      ],
      "expo-asset",
      "expo-font"
    ]
  }
}
